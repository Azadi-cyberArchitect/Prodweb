{
  "routes": [
    {
      "route": "/portal/*",
      "allowedRoles": ["kunde"]
    },
    {
      "route": "/.auth/login/github",
      "statusCode": 404
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/aad?post_login_redirect_uri=/portal/"
    },
    "404": {
      "rewrite": "/index.html"
    }
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/portal/*", "/.auth/*"]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY"
  }
}
